# Flask
FLASK_APP=wsgi:app
FLASK_ENV=production
SECRET_KEY=change-me-in-production

# Database (PostgreSQL in Docker)
DATABASE_URL=postgresql://zenith:password@db:5432/zenith
POSTGRES_USER=zenith
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=zenith

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# TTS (Phase 4)
TTS_PROVIDER=kokoro
KOKORO_URL=http://kokoro:8880
ELEVENLABS_API_KEY=

# Audio storage
AUDIO_STORAGE_PATH=/app/audio

# Resource/attachment storage (Phase 6)
RESOURCE_STORAGE_PATH=/app/resources

# CORS
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Feature flags (comma-separated route names to show coming-soon page)
# Leave empty (or remove) to enable all features locally.
VITE_COMING_SOON=
